# Copy to .env (gitignored) and fill in. NEVER commit real keys.
# The app runs fully WITHOUT any of these (keyword classifier + offline fallbacks).

# ── Secrets (optional) ──
GEMINI_API_KEY=            # enables Gemini CoT classifier + Dzongkha translation
GROQ_API_KEY=             # only needed if USE_TEAM_B_AGENT=1 (Team B LangGraph agent)

# ── Feature flags (safe defaults shown) ──
GEMINI_MODEL_NAME=gemini-2.5-flash
RAG_BACKEND=kb            # kb | docs | supabase
EMIT_CANONICAL_INTENT=1   # 1 | 0
USE_TEAM_B_AGENT=0        # 1 requires GROQ_API_KEY + heavier deps (not free-tier)

# ── Supabase pgvector (only if RAG_BACKEND=supabase; currently a stub upstream) ──
SUPABASE_URL=
SUPABASE_KEY=
