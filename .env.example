# Copy to .env (gitignored) and fill in. NEVER commit real keys.
# The app runs fully WITHOUT any of these (offline keyword classifier + fallbacks).

# ── LLM-first path (RECOMMENDED) ─────────────────────────────────────
# The brain. Any OpenAI-compatible endpoint. See LOCAL_FIRST_PLAN.md.
#
#   Live demo (hosted, exact open weights — paste your DeepInfra key):
#     LLM_BASE_URL=https://api.deepinfra.com/v1/openai
#     LLM_API_KEY=<your DeepInfra key>
#     LLM_MODEL=Qwen/Qwen3-32B
#
#   Fully local / on-prem (data-sovereign vLLM — same model, just a different URL):
#     LLM_BASE_URL=http://localhost:8000/v1
#     LLM_API_KEY=EMPTY
#     LLM_MODEL=Qwen/Qwen3-32B
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3-32B
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60

# ── Legacy / optional secrets ────────────────────────────────────────
GEMINI_API_KEY=            # legacy CoT classifier + Dzongkha translation (offline path only)
GROQ_API_KEY=              # only if USE_TEAM_B_AGENT=1 (Team B LangGraph agent)

# ── Feature flags (safe defaults shown) ──────────────────────────────
GEMINI_MODEL_NAME=gemini-2.5-flash
RAG_BACKEND=kb             # kb | docs | supabase  (LLM-first path uses its own grounding retrieval)
EMIT_CANONICAL_INTENT=1    # 1 | 0
USE_TEAM_B_AGENT=0         # 1 requires GROQ_API_KEY + heavier deps

# ── Supabase pgvector (only if RAG_BACKEND=supabase; stub upstream) ──
SUPABASE_URL=
SUPABASE_KEY=
